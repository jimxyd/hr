# ============================================
# ErgoHub - Environment Variables
# Copy to .env and fill in values
# ============================================

# DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/ergohub_master"
TENANT_DATABASE_BASE_URL="mysql://root:password@localhost:3306"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"

# ENCRYPTION (must be exactly 32 characters)
ENCRYPTION_KEY="your-32-character-encryption-key!"

# PLATFORM SMTP
PLATFORM_SMTP_HOST="smtp.brevo.com"
PLATFORM_SMTP_PORT="587"
PLATFORM_SMTP_USER=""
PLATFORM_SMTP_PASS=""
PLATFORM_FROM_EMAIL="noreply@ergohub.gr"
PLATFORM_FROM_NAME="ErgoHub"

# LINODE OBJECT STORAGE
LINODE_S3_ENDPOINT="https://eu-central-1.linodeobjects.com"
LINODE_S3_BUCKET="ergohub-files"
LINODE_S3_KEY=""
LINODE_S3_SECRET=""
LINODE_S3_REGION="eu-central-1"
LINODE_S3_CDN_URL="https://ergohub-files.eu-central-1.linodeobjects.com"

# VIVA WALLET
VIVA_API_KEY=""
VIVA_SECRET=""
VIVA_MERCHANT_ID=""
VIVA_MODE="test"
VIVA_WEBHOOK_SECRET=""

# PAYPAL
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"
PAYPAL_WEBHOOK_ID=""

# APP
NEXT_PUBLIC_APP_NAME="ErgoHub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="ergohub.gr"
NODE_ENV="development"

# SUPER ADMIN (for setup script)
SUPER_ADMIN_EMAIL="admin@ergohub.gr"
SUPER_ADMIN_PASSWORD="change-this-password!"
SUPER_ADMIN_NAME="Super Admin"
